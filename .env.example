# Landing pages subdomain (no trailing slash)
# Professional subdomain: services.yourdomain.com
VITE_SITE_URL=https://services.yourdomain.com

# Main website URL — optional, shows "Visit main website" in footer
VITE_MAIN_SITE_URL=https://yourdomain.com

# Leave empty to use /api/contact (nginx proxies to API on droplet)
VITE_CONTACT_API_URL=
